# Vi nhan tien. Bat buoc - dien CA HAI dong giong nhau:
RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE
NEXT_PUBLIC_RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Mang MPP: mainnet (mac dinh) hoac testnet.
TEMPO_NETWORK=mainnet

# Token nhan tien. USDC.e tren Tempo - token agent that dung. KHONG dung USDT0.
PAY_TOKEN=0x20c000000000000000000000b9537d11c60e8b50

# Gia moi call (data phap ly, dat nhinh hon).
PULSE_PRICE=0.050000
PULSE_PRICE_AMOUNT=0.05

# URL cong khai khi deploy (KHONG dau / cuoi).
BASE_URL=http://localhost:3000

# Email lien he. BAT BUOC cho SEC EDGAR (SEC doi User-Agent co email).
CONTACT_EMAIL=

# Secret ky MPP challenge.
MPP_SECRET_KEY=

# UK Companies House: API key FREE (dang ky tai developer.company-information.service.gov.uk).
# De trong thi provider UK tu bao "chua cau hinh", cac nguon khac van chay.
COMPANIES_HOUSE_API_KEY=

# Preview key (de TEST bo qua thanh toan). XOA tren production khi xong.
PREVIEW_KEY=
